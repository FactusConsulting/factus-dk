---
import { site } from "../config/site";

const isExternal = (item: any) => "external" in item && item.external;
---

<header class="sticky top-0 z-50 backdrop-blur-md bg-white/80 border-b border-ink-100">
  <div class="container-page flex items-center justify-between h-16 md:h-18">
    <a href="/" class="flex items-center gap-2.5 group">
      <span class="relative flex items-center justify-center w-9 h-9 rounded-lg bg-gradient-to-br from-brand-600 to-accent-600 text-white font-bold text-sm shadow-sm">
        F
      </span>
      <span class="font-display font-bold text-lg tracking-tight text-ink-900">
        factus<span class="text-brand-600">.</span>dk
      </span>
    </a>

    <nav class="hidden md:flex items-center gap-8">
      {site.nav.map((item) => (
        <a
          href={item.href}
          target={isExternal(item) ? "_blank" : undefined}
          rel={isExternal(item) ? "noopener" : undefined}
          class="text-sm font-medium text-ink-600 hover:text-ink-900 transition-colors"
        >
          {item.label}
        </a>
      ))}
    </nav>

    <a href="/#kontakt" class="hidden md:inline-flex btn-primary !py-2.5 !px-4 !text-sm">
      Book et møde
    </a>

    <button
      id="mobile-menu-toggle"
      type="button"
      class="md:hidden inline-flex items-center justify-center w-10 h-10 rounded-md text-ink-700 hover:bg-ink-100"
      aria-label="Åbn menu"
      aria-expanded="false"
    >
      <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
      </svg>
    </button>
  </div>

  <div id="mobile-menu" class="hidden md:hidden border-t border-ink-100 bg-white">
    <nav class="container-page py-4 flex flex-col gap-1">
      {site.nav.map((item) => (
        <a
          href={item.href}
          target={isExternal(item) ? "_blank" : undefined}
          rel={isExternal(item) ? "noopener" : undefined}
          class="px-3 py-2.5 rounded-md text-base font-medium text-ink-700 hover:bg-ink-50"
        >
          {item.label}
        </a>
      ))}
      <a href="/#kontakt" class="mt-2 btn-primary">Book et møde</a>
    </nav>
  </div>
</header>

<script>
  const toggle = document.getElementById("mobile-menu-toggle");
  const menu = document.getElementById("mobile-menu");
  toggle?.addEventListener("click", () => {
    const expanded = toggle.getAttribute("aria-expanded") === "true";
    toggle.setAttribute("aria-expanded", String(!expanded));
    menu?.classList.toggle("hidden");
  });
</script>
