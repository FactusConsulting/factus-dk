---
import { engagements } from "../data/experience";

const recent = engagements.slice(0, 5);
---

<section id="erfaring" class="section-y bg-ink-50/50 border-y border-ink-100">
  <div class="container-page">
    <div class="flex items-end justify-between flex-wrap gap-6">
      <div class="max-w-2xl">
        <span class="eyebrow">Seneste engagementer</span>
        <h2 class="heading-2 mt-3">Hvor jeg har været på arbejde.</h2>
        <p class="lead mt-5">
          Et udsnit af mine seneste freelance-engagementer. Den fulde liste — over 20
          opgaver hos store og mellemstore danske og nordiske virksomheder — finder du på erfaringssiden.
        </p>
      </div>
      <a href="/erfaring" class="btn-secondary">
        Se hele listen
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3" />
        </svg>
      </a>
    </div>

    <ol class="mt-12 relative border-l-2 border-ink-200 ml-3">
      {recent.map((e) => (
        <li class="relative pl-6 pb-8 last:pb-0">
          <span class="absolute -left-[7px] top-1.5 w-3 h-3 rounded-full bg-brand-600 ring-4 ring-white"></span>
          <p class="text-xs font-semibold uppercase tracking-wider text-brand-700">{e.period}</p>
          <h3 class="font-display font-bold text-lg text-ink-900 mt-1">{e.client}</h3>
          <p class="prose-body mt-2 text-[0.95rem]">{e.summary}</p>
          {e.tags && e.tags.length > 0 && (
            <div class="mt-3 flex flex-wrap gap-2">
              {e.tags.map((t) => (
                <span class="px-2.5 py-1 rounded-md bg-white border border-ink-200 text-xs text-ink-700 font-medium">{t}</span>
              ))}
            </div>
          )}
        </li>
      ))}
    </ol>
  </div>
</section>
