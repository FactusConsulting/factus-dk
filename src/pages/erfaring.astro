---
import BaseLayout from "../layouts/BaseLayout.astro";
import { engagements } from "../data/experience";
---

<BaseLayout
  title="Erfaring"
  description="Komplet liste over Lars W. Andersens freelance-engagementer som DevOps-, platform- og Kubernetes-konsulent gennem 15+ år."
>
  <section class="bg-white border-b border-ink-100">
    <div class="container-page pt-20 md:pt-28 pb-12">
      <span class="eyebrow">Erfaring</span>
      <h1 class="heading-1 mt-4 max-w-3xl">15+ års freelance — over 20 engagementer.</h1>
      <p class="lead mt-6 max-w-2xl">
        Kronologisk oversigt over de virksomheder jeg har arbejdet med, og hvad jeg
        har lavet hos dem. Fra BizTalk-integrationer i 2007 til Kubernetes-platforme
        og AI-infrastruktur i dag.
      </p>
    </div>
  </section>

  <section class="section-y bg-ink-50/50">
    <div class="container-page">
      <ol class="relative border-l-2 border-ink-200 ml-3">
        {engagements.map((e) => (
          <li class="relative pl-6 pb-10 last:pb-0">
            <span class="absolute -left-[7px] top-1.5 w-3 h-3 rounded-full bg-brand-600 ring-4 ring-ink-50/50"></span>
            <p class="text-xs font-semibold uppercase tracking-wider text-brand-700">{e.period}</p>
            <h2 class="font-display font-bold text-xl text-ink-900 mt-1">{e.client}</h2>
            <p class="prose-body mt-2 text-[0.95rem] max-w-3xl">{e.summary}</p>
            {e.tags && e.tags.length > 0 && (
              <div class="mt-3 flex flex-wrap gap-2">
                {e.tags.map((t) => (
                  <span class="px-2.5 py-1 rounded-md bg-white border border-ink-200 text-xs text-ink-700 font-medium">{t}</span>
                ))}
              </div>
            )}
          </li>
        ))}
      </ol>

      <div class="mt-16 p-8 md:p-10 rounded-2xl bg-gradient-to-br from-ink-900 to-brand-900 text-white">
        <h2 class="font-display text-2xl md:text-3xl font-bold tracking-tight">Søger I lignende kompetencer?</h2>
        <p class="mt-3 text-ink-200 max-w-2xl">
          Jeg er tilgængelig for nye opgaver — særligt inden for Kubernetes,
          platform engineering og AI-infrastruktur. Ræk ud så tager vi en snak.
        </p>
        <a href="/#kontakt" class="mt-6 inline-flex items-center gap-2 bg-white text-ink-900 px-5 py-3 rounded-lg font-semibold text-sm hover:bg-ink-100 transition-colors">
          Kontakt mig
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3" />
          </svg>
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
